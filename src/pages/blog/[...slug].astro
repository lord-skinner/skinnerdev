---
import { type CollectionEntry, getCollection, getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const entry = await getEntry("blog", post.id);

if (!entry) {
  throw new Error(`Blog post not found: ${post.id}`);
}

const { Content } = await render(entry);

// Reading time
const words = entry.body?.trim().split(/\s+/).length ?? 0;
const readingTime = `${Math.max(1, Math.ceil(words / 200))} min read`;

// Series navigation
let prevPost: CollectionEntry<"blog"> | undefined;
let nextPost: CollectionEntry<"blog"> | undefined;

if (post.data.series) {
  const allPosts = await getCollection("blog");
  const seriesPosts = allPosts
    .filter((p) => p.data.series === post.data.series)
    .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));

  const idx = seriesPosts.findIndex((p) => p.id === post.id);
  if (idx > 0) prevPost = seriesPosts[idx - 1];
  if (idx < seriesPosts.length - 1) nextPost = seriesPosts[idx + 1];
}
---

<BaseLayout title={`${post.data.title} | Blog`} description={post.data.description}>
  <Header />
  <main class="section-shell py-20">
    <article class="mx-auto max-w-none">
      <a href={withBase("/blog/")} class="text-sm text-muted transition hover:text-primary">&larr; Back to Blog</a>
      <h1 class="mt-4 text-4xl font-bold">{post.data.title}</h1>
      <p class="mt-2 flex items-center gap-3 text-sm text-muted">
        <span>
          {post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </span>
        <span>&middot;</span>
        <span>{readingTime}</span>
      </p>
      {post.data.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
      <div class="prose prose-lg mt-8 max-w-none dark:prose-invert">
        <Content />
      </div>

      {(prevPost || nextPost) && (
        <nav class="mt-12 grid gap-4 sm:grid-cols-2" aria-label="Series navigation">
          {prevPost ? (
            <a href={withBase(`/blog/${prevPost.id}/`)} class="card group flex flex-col gap-1">
              <span class="text-xs uppercase tracking-wider text-muted">Previous</span>
              <span class="font-semibold group-hover:text-primary">{prevPost.data.title}</span>
            </a>
          ) : <div />}
          {nextPost && (
            <a href={withBase(`/blog/${nextPost.id}/`)} class="card group flex flex-col gap-1 text-right">
              <span class="text-xs uppercase tracking-wider text-muted">Next</span>
              <span class="font-semibold group-hover:text-primary">{nextPost.data.title}</span>
            </a>
          )}
        </nav>
      )}
    </article>
  </main>

  <style>
    :global(.mermaid-container) {
      margin: 2rem 0;
      padding: 1.5rem;
      border-radius: 0.75rem;
      background: var(--color-panel);
      border: 1px solid var(--color-border);
      overflow-x: auto;
    }
    :global(.mermaid-container .mermaid) {
      display: flex;
      justify-content: center;
    }
    :global(.mermaid-container svg) {
      max-width: 100%;
      height: auto;
    }
    /* Constrain prose text for readability, but let code/diagrams go full width */
    .prose > p,
    .prose > ul,
    .prose > ol,
    .prose > blockquote,
    .prose > h1,
    .prose > h2,
    .prose > h3,
    .prose > h4,
    .prose > table {
      max-width: 75ch;
    }
  </style>

  <script type="module">
    import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";

    const diagramSources = [];

    function getThemeVars() {
      const s = getComputedStyle(document.documentElement);
      const v = (name) => s.getPropertyValue(name).trim();
      return {
        primaryColor: v("--color-primary"),
        primaryTextColor: v("--color-text"),
        primaryBorderColor: v("--color-muted"),
        lineColor: v("--color-muted"),
        mainBkg: v("--color-panel-soft"),
        nodeBorder: v("--color-muted"),
        secondaryColor: v("--color-panel"),
        tertiaryColor: v("--color-panel"),
        textColor: v("--color-text"),
        secondaryTextColor: v("--color-muted"),
        tertiaryTextColor: v("--color-muted"),
      };
    }

    function initMermaid() {
      const isDark = document.documentElement.classList.contains("dark");
      mermaid.initialize({
        startOnLoad: false,
        theme: "base",
        themeVariables: getThemeVars(),
        fontFamily: "Roboto, sans-serif",
        fontSize: 16,
        flowchart: {
          padding: 20,
          nodeSpacing: 50,
          rankSpacing: 50,
          useMaxWidth: false,
        },
      });

      const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
      blocks.forEach((pre) => {
        const code = pre.querySelector("code");
        if (!code) return;
        const src = code.textContent;
        diagramSources.push(src);
        const container = document.createElement("div");
        container.className = "mermaid-container not-prose";
        const inner = document.createElement("div");
        inner.className = "mermaid";
        inner.textContent = src;
        container.appendChild(inner);
        pre.replaceWith(container);
      });

      mermaid.run();
    }

    function reinitMermaid() {
      mermaid.initialize({
        startOnLoad: false,
        theme: "base",
        themeVariables: getThemeVars(),
        fontFamily: "Roboto, sans-serif",
        fontSize: 16,
        flowchart: {
          padding: 20,
          nodeSpacing: 50,
          rankSpacing: 50,
          useMaxWidth: false,
        },
      });

      const containers = document.querySelectorAll(".mermaid-container");
      containers.forEach((container, i) => {
        if (i >= diagramSources.length) return;
        const inner = container.querySelector(".mermaid");
        if (!inner) return;
        inner.removeAttribute("data-processed");
        inner.innerHTML = "";
        inner.textContent = diagramSources[i];
      });

      mermaid.run();
    }

    initMermaid();

    const observer = new MutationObserver(() => reinitMermaid());
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class", "data-theme"],
    });
  </script>
</BaseLayout>
