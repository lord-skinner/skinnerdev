<div class="flex items-center gap-2">
  <select
    id="theme-picker"
    class="rounded-md border border-border bg-panel px-2 py-1 text-xs text-text"
    aria-label="Color theme"
  >
    <option value="blue-munsell">Blue Munsell</option>
    <option value="blue">Blue</option>
    <option value="green">Green</option>
    <option value="orange">Orange</option>
    <option value="purple">Purple</option>
    <option value="red">Red</option>
    <option value="slate">Slate</option>
    <option value="yellow">Yellow</option>
  </select>
  <button
    id="mode-toggle"
    type="button"
    class="rounded-md border border-border bg-panel px-2 py-1 text-xs text-text"
    aria-label="Toggle dark mode"
  >
    Dark/Light
  </button>
</div>

<script>
  const picker = document.querySelector("#theme-picker") as HTMLSelectElement | null;
  const modeToggle = document.querySelector("#mode-toggle") as HTMLButtonElement | null;

  if (picker) {
    const currentTheme = document.documentElement.getAttribute("data-theme") ?? "blue-munsell";
    picker.value = currentTheme;

    picker.addEventListener("change", (event) => {
      const selected = (event.target as HTMLSelectElement).value;
      document.documentElement.setAttribute("data-theme", selected);
      localStorage.setItem("theme", selected);
    });
  }

  modeToggle?.addEventListener("click", () => {
    const root = document.documentElement;
    const isDark = root.classList.contains("dark");
    if (isDark) {
      root.classList.remove("dark");
      localStorage.setItem("mode", "light");
      return;
    }
    root.classList.add("dark");
    localStorage.setItem("mode", "dark");
  });
</script>
